# =============================================================================
# MISS MINUTES - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this to .env and fill in your values

# -----------------------------------------------------------------------------
# SLACK CONFIGURATION (Required)
# Get from: https://api.slack.com/apps -> Your App
# -----------------------------------------------------------------------------

# Bot User OAuth Token (starts with xoxb-)
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Signing Secret (from Basic Information page)
SLACK_SIGNING_SECRET=your-signing-secret-here

# -----------------------------------------------------------------------------
# AI CONFIGURATION (Required)
# Get from: https://console.anthropic.com
# -----------------------------------------------------------------------------

ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Model to use (optional, defaults to claude-sonnet-4-20250514)
# CLAUDE_MODEL=claude-sonnet-4-20250514

# -----------------------------------------------------------------------------
# MYNOS CONFIGURATION (Required)
# -----------------------------------------------------------------------------

# URL to your time tracking system
MYNOS_URL=https://mynos.example.com

# -----------------------------------------------------------------------------
# DEFAULT REMINDER SETTINGS (Optional)
# These are defaults for new users. Each user can customize their own.
# -----------------------------------------------------------------------------

# Default timezone for new users
DEFAULT_TIMEZONE=America/New_York

# Default reminder time (24-hour format)
DEFAULT_REMINDER_TIME=16:30

# Default reminder day
DEFAULT_REMINDER_DAY=friday

# -----------------------------------------------------------------------------
# SERVER SETTINGS (Optional)
# -----------------------------------------------------------------------------

# Host and port
HOST=0.0.0.0
PORT=3000

# Debug mode (set to true for development)
DEBUG=false

# -----------------------------------------------------------------------------
# RAG SETTINGS (Optional)
# -----------------------------------------------------------------------------

# Directory containing knowledge base documents
DATA_DIR=data

# Chunk size for document splitting
CHUNK_SIZE=500

# Number of candidates for BM25 retrieval
BM25_TOP_K=20

# Number of results after reranking
RERANK_TOP_K=5
